generator client {
	provider = "prisma-client-js"
}

datasource db {
	provider = "postgresql"
	url      = env("DATABASE_URL")
}

enum UserRole {
	ADMIN
	SALES
}

enum ProductCategory {
	PANEL
	PUMP
	INVERTER
	ACCESSORY
}

enum QuoteStatus {
	PENDING
	ACCEPTED
	REJECTED
}

model User {
	id       String   @id @default(uuid())
	email    String   @unique
	password String
	role     UserRole @default(SALES)
	fullName String?
	isActive Boolean  @default(true)
	lastLoginAt DateTime?
	createdAt DateTime @default(now())
	updatedAt DateTime @updatedAt

	quotes Quote[]
}

model Client {
	id        String @id @default(uuid())
	name      String
	phone     String?
	email     String?
	address   String?
	city      String?
	region    String?
	country   String?
	notes     String?
	latitude  Float
	longitude Float
	createdAt DateTime @default(now())
	updatedAt DateTime @updatedAt
	deletedAt DateTime?

	quotes Quote[]

	@@index([name])
	@@index([deletedAt])
}

model Product {
	id       String          @id @default(uuid())
	sku      String?         @unique
	name     String
	brand    String?
	category ProductCategory
	unit     String?         @default("piece")
	stock    Int             @default(0)
	isActive Boolean         @default(true)
	price    Float

	/// PostgreSQL: stored as JSONB by default.
	specifications Json
	createdAt DateTime @default(now())
	updatedAt DateTime @updatedAt
	deletedAt DateTime?

	@@index([category])
	@@index([deletedAt])
}

model Quote {
	id       String      @id @default(uuid())
	quoteNumber String   @unique @default(cuid())
	clientId String
	userId   String
	status   QuoteStatus @default(PENDING)

	totalPrice Float
	currency   String    @default("MAD")
	validUntil DateTime?
	notes      String?
	deletedAt  DateTime?

	// Inputs
	wellDepth         Float
	irrigationSurface Float
	cropType          String
 
	// Outputs
	dailyWaterNeed Float
	requiredPower  Float
	panelCount     Int
	pumpModel      String
	basinVolume    Float

	// MVP Fields (optional to preserve backward compatibility)
	culture        String?
	surfaceHa      Float?
	volumeJour     Float?
	profondeur     Float?
	typeInstall    String?
	tensionSysteme String?
	inclinaison    Float?

	totalHT        Float? @default(0)
	tva            Float? @default(0)
	totalTTC       Float? @default(0)

	createdAt DateTime @default(now())
	updatedAt DateTime @updatedAt

	client Client @relation(fields: [clientId], references: [id])
	user   User   @relation(fields: [userId], references: [id])
	items  QuoteItem[]

	@@index([clientId])
	@@index([status])
	@@index([deletedAt])
}

model QuoteItem {
	id             String   @id @default(uuid())
	quoteId        String
	designation    String
	marque         String?
	quantite       Int
	prixUnitaireHT Float
	totalLigneHT   Float

	quote          Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model PanneauPhotovoltaique {
	id            String   @id @default(uuid())
	marque        String
	modele        String
	puissanceCrete Decimal
	technologie   String
	tensionVmp    Decimal
	courantImp    Decimal
	prixIndicatif Decimal
	createdAt     DateTime @default(now())
	updatedAt     DateTime @updatedAt
}

model PompeHydraulique {
	id            String   @id @default(uuid())
	marque        String
	modele        String
	puissance     Decimal
	debitNominal  Decimal
	hmtMax        Decimal
	prixIndicatif Decimal
	createdAt     DateTime @default(now())
	updatedAt     DateTime @updatedAt
}

model VariateurSolaire {
	id               String   @id @default(uuid())
	marque           String
	modele           String
	puissanceMax     Decimal
	plageMpptMin     Decimal
	plageMpptMax     Decimal
	courantSortieMax Decimal
	prixIndicatif    Decimal
	createdAt        DateTime @default(now())
	updatedAt        DateTime @updatedAt
}
